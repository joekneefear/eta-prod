    @staticmethod
    def dp_exit(code=0, error=None, warn=None):
        #logger = self.logger
        error_list = []
        warn_list = []
        out_file = "err.jnk"
        trace = "\t".join(traceback.format_stack()).replace('\n', '\t')
        
        if error is not None:
            if isinstance(error, list):
                error_list.extend(error)
            else:
                error_list.append(error)

            error_list.append(trace)

        if warn is not None:
            if isinstance(warn, list):
                warn_list.extend(warn)
            else:
                warn_list.append(warn)

        err_count = len(error_list)
        warn_count = len(warn_list)

        with open(out_file, "w") as outfile:
            outfile.write(f"{err_count}\t{warn_count}\n")

            for msg in error_list:
                outfile.write(f"1\t9001\tE\t0\t0\t{msg}\n")
                Log.ERROR(f"ERROR: {msg}")

            for msg in warn_list:
                outfile.write(f"1\t9002\tW\t0\t0\t{msg}\n")
                #print(f"WARNING: {msg}")
                Log.WARN(f"WARNING: {msg}")

        #Log.INFO("############ End " sys.argv[0] + " script (code = " + code +")")
        log_message = f"############ End {sys.argv[0]} script (code = {code}) #######"
        Log.INFO(log_message)

        if code == 10:
            sys.exit(10)
        elif code == 100:
            sys.exit(0)
        else:
            sys.exit(code)
            
    @staticmethod       
    def process_command_line_args(arguments):
        args_dict = {}
        in_file = arguments.pop(0)
        args_dict['infile'] = in_file
        for arg in arguments:
            key_value = arg.split('=')
            #print(f"KEY_VALUE={key_value}")
            if len(key_value) == 2:
                key, value = key_value
                key = key.replace("--", "")
                #print(f"KEY={key}||VALUE={value}")
                args_dict[key] = value
        #print(args_dict)
        return args_dict
    
