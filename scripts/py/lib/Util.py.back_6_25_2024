    @staticmethod
    def has_five_minutes_passed(earlier_timestamp):
        """Check if five minutes have passed since the earlier timestamp."""
        current_timestamp = time.time()
        time_difference = current_timestamp - earlier_timestamp
        return time_difference >= 300  # 300 seconds is equivalent to 5 minutes



