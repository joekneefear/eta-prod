			}
		}

	}
}

##################
# CREATE TESTPLAN 
##################
sub create_tp
{
        my $DateTime      = `date '+%m%d%y%H%M%S'`;
        chomp($DateTime);
        $tp_filename  =$mftFile . ".TP";
        $tp_filename  =~ s/YLD|TFC/DTA/i; 
        open FH, ">$tp_filename" or die "error msg: $!";

        #############
        # EMIR RECORD
        #############
        %out::emir              = %{$out::init{emir}};
        $out::emir{mode_cod}    = "C";
        $out::emir{setup_t}     = stdf_time();
        $out::emir{job_nam}     = $testplan;
        $out::emir{job_rev}     = $testplan_rev;
        $out::emir{spec_nam}    = $testplan;
        $out::emir{spec_rev}    = $testplan_rev;
	$out::emir{spec_rev}    = pad($out::emir{spec_rev},"\0");
        print FH &out::pack_EMIR(\%out::emir);

        ##############
        # EPDR RECORD
        ##############
        foreach (sort {$a<=>$b} keys %tp)
        {
		next if $tp{$_}{LIMIT_ITEM_NAME} =~ /$skip_tests/i;
		next if $tp{$_}{LIMIT_ITEM_NAME} eq "" || $tp{$_}{LOW_SPEC_LIM} eq "" || $tp{$_}{HI_SPEC_LIM} eq "";
                %out::epdr           = %{$out::init{epdr}};
                $out::epdr{test_num} = $_;
                $out::epdr{units}    = $tp{$_}{LIMIT_UNIT};
                $out::epdr{lo_limit} = $tp{$_}{LOW_SPEC_LIM};
                $out::epdr{hi_limit} = $tp{$_}{HI_SPEC_LIM};
		$out::epdr{lo_censr} = $tp{$_}{LOW_CENSOR}||-1e20;
		$out::epdr{hi_censr} = $tp{$_}{HI_CENSOR}||1e20;
                $out::epdr{test_nam} = $tp{$_}{LIMIT_ITEM_NAME};
                $out::epdr{test_txt} = $tp{$_}{BIAS};
		$out::epdr{sbin_num} = $tp{$_}{SBIN_NUM} if exists($tp{$_}{SBIN_NUM});
		$out::epdr{sbin_nam} = $tp{$_}{SBIN_NAM} if exists($tp{$_}{SBIN_NAM});
                $out::epdr{opt_flg}  = ($_==1 && $tp{$_}{LIMIT_ITEM_NAME} eq "DEF") ? "00100000" : "00000000";
                print FH &out::pack_EPDR(\%out::epdr);
        }

        #############
        # MRR RECORD
        #############
        %out::mrr = %{$out::init{mrr}};
        $out::mrr{finish_t} = stdf_time();
        print FH &out::pack_MRR(\%out::mrr);

	close(FH);
}


#######################
# CREATE STDF DATAFILE
#######################
sub create_td
{
	##################
	# COUNT VARIABLES
	##################
	my $pir_count    = 0;
	my $ptr_count    = 0;
	my $good_units   = 0;
	my $max_hbin_num = 0;
	   $max_hbin_num = $dta_max_hbin_num if $use_dta_bin  eq "Y"; ### USE DTA HBIN SUMM DATA
	   $max_hbin_num = $yld_max_hbin_num if $req_yld_file eq "Y"; ### USE YLD HBIN SUMM DATA


	##############
	# TD FILENAME
	##############
        $td_filename  =$mftFile . ".TD";
        $td_filename  =~ s/YLD|TFC/DTA/i;    
        open OUTFILE, ">$td_filename" or die "Could not open file: $!";

        ##############
        # EMIR RECORD
        ##############
        %out::emir           = %{$out::init{emir}} ;
        $out::emir{lot_type} = $lot_type; ###"P";
        $out::emir{mode_cod} = "P";
        $out::emir{setup_t}  = $session_datetime;
        $out::emir{start_t}  = $session_datetime;
        $out::emir{lot_id}   = $lotid;
        $out::emir{job_nam}  = $testplan;
        $out::emir{job_rev}  = $testplan_rev;
	$out::emir{device}   = $device||$testplan;
	$out::emir{part_typ} = $glob_part_type if $glob_part_type ne "" || $device || $testplan;
	#$out::emir{part_typ} = $glob_part_type if $glob_part_type ne "";
        $out::emir{spec_nam} = $testplan;
        $out::emir{spec_rev} = $testplan_rev;
	$out::emir{spec_rev} = pad($out::emir{spec_rev},"\0");
	$out::emir{oper_nam} = $operator  if $operator  ne "";
	$out::emir{node_nam} = $eqpt_id   if $eqpt_id   ne "";
        $out::emir{tstr_typ} = "TESEC";			
	$out::emir{stat_num} = $station{$station}||0;
	$out::emir{shwb_cnt} = keys %dta_bin||$max_hbin_num||0;
	$out::emir{sswb_cnt} = keys %sbin||0;
	$out::emir{wswb_cnt} = $wsbin_cnt;
	$out::emir{whwb_cnt} = $wafer_cnt * $max_hbin_num if $wafer_cnt > 0;
        $out::emir{facility} = $plant	  if $plant     ne "";				
	$out::emir{test_cod} = $testrun || 0;
	$out::emir{sblot_id}   = $glob_sub_lotid if $glob_sub_lotid ne "";
        print OUTFILE &out::pack_EMIR(\%out::emir);


	###############
        # SOURCE LOTID
        ###############
        if ($glob_sub_lotid ne "" || $glob_src_lot ne "")
        #if ($glob_src_lot ne "")
        {
                %out::ltr           = %{$out::init{ltr}};
                $out::ltr{lot_id}   = $glob_src_lot||$glob_sub_lotid;
                #$out::ltr{lot_id}   = $glob_src_lot || $glob_sub_lotid if $glob_sub_lotid ne "";
                print OUTFILE &out::pack_LTR(\%out::ltr);
        }


        foreach my $wafer_id(sort {$a <=> $b} keys %td)
	{

		#############
        	# WIR RECORD
        	#############
        	if ($wafer_id > 0)
        	{
                	%out::wir            = %{$out::init{wir}};
                	$out::wir{wafer_id}  = $wafer_id;
                	print OUTFILE &out::pack_WIR(\%out::wir);
        	}
		

		my $loc_part_cnt = 0;
		my $parts 	 = $td{$wafer_id};
		my ($x,$y) = &getXYLocCol();
        	foreach my $serial(sort {$a <=> $b} keys %$parts)
        	{
			my $addrForXYLoc      = $$parts{$serial}{READINGS};
                	#############
                	# PIR RECORD
                	#############
                	%out::pir             = %{$out::init{pir}};
			if(($$addrForXYLoc{$x} ne "" || $$addrForXYLoc{$y} ne "") && $XYLocFlag eq "On") {
				$out::pir{x_coord}  = $$addrForXYLoc{$x} if $$addrForXYLoc{$x} ne "";
				$out::pir{y_coord}  = $$addrForXYLoc{$y} if $$addrForXYLoc{$y} ne "";
			}
                	$out::pir{part_id}    = $serial;
                	print OUTFILE &out::pack_PIR(\%out::pir);
			$pir_count++;
		
                	#############
                	# PTR RECORD
                	#############
			my $x         = 0;
			my $test_flag = 0;
			my $addr      = $$parts{$serial}{READINGS};
			   $loc_part_cnt++;
			foreach $testno(sort {$a<=>$b} keys %$addr)
			{
				next if    $tp{$testno}{LIMIT_ITEM_NAME} eq "" 
					|| $tp{$testno}{LIMIT_ITEM_NAME} =~ /$skip_tests/i
					|| $tp{$testno}{LOW_SPEC_LIM}    eq "" 
					|| $tp{$testno}{HI_SPEC_LIM}     eq "";


                		%out::ptr           = %{$out::init{ptr}};
                        	$out::ptr{test_num} = $testno;
                        	$out::ptr{result}   = $$addr{$testno};
                        	$out::ptr{test_flg} = "01000000";
				$out::ptr{test_nam} = $tp{$testno}{LIMIT_ITEM_NAME};
                        	print OUTFILE &out::pack_PTR(\%out::ptr);

				$ptr_count++;
				$x++;
                	}

			### COUNT GOOD UNIT ###
			$good_units++ if $$parts{$serial}{BIN} == $good_hbin_num;
			$test_flag=1  if $$parts{$serial}{BIN} != $good_hbin_num;


                	###############
                	# EPRR RECORD
                	###############
                	%out::eprr           = %{$out::init{eprr}};
                	$out::eprr{num_test} = $x;
                	$out::eprr{part_id}  = $serial;
	        	$out::eprr{hard_bin} = $$parts{$serial}{BIN};	
	        	$out::eprr{soft_bin} = $$parts{$serial}{BIN};	
			if(($$addrForXYLoc{$x} ne "" || $$addrForXYLoc{$y} ne "") && $XYLocFlag eq "On") {
				#$out::pir{x_coord}  = $$addrForXYLoc{$x} if $$addrForXYLoc{$x} ne "";
				#$out::pir{y_coord}  = $$addrForXYLoc{$y} if $$addrForXYLoc{$y} ne "";
				$out::eprr{x_coord}  = $out::pir{x_coord};
				$out::eprr{y_coord}  = $out::pir{y_coord};
			}
			$out::eprr{part_flg} = "0000".$test_flag."000";
                	print OUTFILE &out::pack_EPRR(\%out::eprr);
		}
 

		############################
		# ADD WAFER SUMMARY RECORDS
		############################
        	if($wafer_id > 0)
        	{
        		##############
        		# WSBR RECORD
        		##############
        		foreach my $bin_num(sort {$a<=>$b} keys %{$wsbin{$wafer_id}})
        		{
				next if $tp{$bin_num}{LIMIT_ITEM_NAME} =~ /$skip_tests/i;
	
                		%out::wsbr           = %{$out::init{wsbr}};
                		$out::wsbr{sbin_num} = $bin_num;
                		$out::wsbr{sbin_nam} = $tp{$bin_num}{LIMIT_ITEM_NAME};
                		$out::wsbr{sbin_cnt} = $wsbin{$wafer_id}{$bin_num}||0;
                		print OUTFILE &out::pack_WSBR(\%out::wsbr);
        		}


        		##############
        		# WHBR RECORD
        		##############
			my $addr      = "";
			$loc_part_cnt = 0 if $wafer_id > 0;
			if ( $use_dta_bin eq "N")
			{
				### FROM YLD FILE ###
				$addr = $whbin{$wafer_id} if exists($whbin{$wafer_id});
			}
			elsif ($use_dta_bin eq "Y")
			{
				### FROM DTA FILE ###
				$addr = $dta_whbin{$wafer_id} if exists($dta_whbin{$wafer_id});
			}
		
        		foreach my $bin_num(1..$max_hbin_num)
        		{
                		%out::whbr           = %{$out::init{whbr}};
                		$out::whbr{hbin_num} = $bin_num;
                		$out::whbr{hbin_nam} = "BIN".$bin_num;
                		$out::whbr{hbin_cnt} = $$addr{$bin_num}||0;
                		print OUTFILE &out::pack_WHBR(\%out::whbr);

				### COUNT TOTAL TESTED PARTS PER WAFER ###
				$loc_part_cnt += $whbin{$wafer_id}{$bin_num}||0;
        		}


        		#############
        		# WRR RECORD
        		#############
                	%out::wrr           = %{$out::init{wrr}};
                	$out::wrr{wafer_id} = $wafer_id;
			$out::wrr{part_cnt} = $die_cnt_per_wafer{$wafer_id}||$loc_part_cnt||0;
			$out::wrr{good_cnt} = $whbin{$wafer_id}{1} if exists($whbin{$wafer_id}{1});
                	print OUTFILE &out::pack_WRR(\%out::wrr);
        	}
	}


	#############
        # SBR RECORD
        #############
	foreach my $bin_num(sort {$a<=>$b} keys %sbin)
        {

                %out::sbr           = %{$out::init{sbr}};
                $out::sbr{sbin_num} = $bin_num;
                $out::sbr{sbin_cnt} = $sbin{$bin_num};
                print OUTFILE &out::pack_SBR(\%out::sbr);
        }


        #############
        # HBR RECORD
        #############
	my %loc_hbin = ();
	if ($use_dta_bin eq "N")
	{
		### FROM YLD FILE ###
        	%loc_hbin = %hbin if keys %hbin > 0;      		    ### FROM YLD FILE
	}
	elsif ($use_dta_bin eq "Y")
	{
		### FROM DTA FILE ###
        	%loc_hbin = %dta_hbin if keys %dta_hbin > 0;
	}

       	foreach my $bin_num(1..$max_hbin_num)
       	{
               	%out::hbr           = %{$out::init{hbr}};
               	$out::hbr{hbin_num} = $bin_num;
               	$out::hbr{hbin_nam} = "BIN".$bin_num;
               	$out::hbr{hbin_cnt} = $loc_hbin{$bin_num}||0;
               	print OUTFILE &out::pack_HBR(\%out::hbr);
       	}


        #############
        # MRR RECORD
        #############
        %out::mrr            = %{$out::init{mrr}};
        $out::mrr{finish_t}  = $session_datetime;		
        $out::mrr{part_cnt}  = $yld_total_part_cnt||$logged_qty||0;
	$out::mrr{disp_cod}  = $lot_disp;
	$out::mrr{good_cnt}  = $hbin{1}||$good_units;
        print OUTFILE &out::pack_MRR(\%out::mrr);
        close OUTFILE;


	########################
        # UPDATE EMIR{PRES_CNT}
        ########################
        $out::emir{psum_cnt} = $pir_count;			
        $out::emir{pres_cnt} = $ptr_count;                      #<-- TOTAL COUNT OF PTR RECORDS
        &out::update_EMIR(\%out::emir, $td_filename) ;

}




##################################
# CONVERT TO BASE UNIT (NOT USED)
##################################
sub convert_to_base_unit
{
        my $value      = shift;
	my $unit       = shift;
        my $multiplier = 1;

        #print "orig: unit=$unit, value=$value\n";

        if ($unit =~ /^p/)
        {
                $unit       =~ s/^p//;
                $multiplier = 1e-12;
        }
        elsif ($unit =~ /^n/)
        {
                $unit       =~ s/^n//;
                $multiplier = 1e-9;
        }
        elsif ($unit =~ /^u/)
        {
                $unit       =~ s/^u//;
                $multiplier = 1e-6;
        }
        elsif ($unit =~ /^m/)
        {
                $unit       =~ s/^m//;
                $multiplier = 1e-3;
        }
        elsif ($unit =~ /^K/)
        {
                $unit       =~ s/^K//;
                $multiplier = 1e3;
        }
        elsif ($unit =~ /^M/)
        {
                $unit       =~ s/^M//;
                $multiplier = 1e6;
        }
        elsif ($unit =~ /^G/)
        {
                $unit       =~ s/^G//;
                $multiplier = 1e9;
        }

        $value *= $multiplier;

        #print "new: unit=$unit , value=$value , mul=$multiplier\n"; 
        return($value, uc($unit));
}

sub getXYLocCol {

	my @arr = ();
	my $xLoc = "";
	my $yLoc = "";

	foreach (sort {$a<=>$b} keys %tp)
        {
		$xLoc = $_ if $tp{$_}{LIMIT_ITEM_NAME} =~ /XLOC/i;
		$yLoc = $_ if $tp{$_}{LIMIT_ITEM_NAME} =~ /YLOC/i;
		
        }
	push(@arr, $xLoc);
	push(@arr, $yLoc);
	return @arr;
}
