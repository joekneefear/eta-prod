			print "\tHI_LIMIT   : $tp{$no}{HI_SPEC_LIM}\n";
			print "\tBIAS       : $tp{$no}{BIAS}\n";
			print "\tTIME_COND  : $tp{$no}{TIME_COND}\n";
			print "\tTIME_UNIT  : $tp{$no}{TIME_UNIT}\n";
			print "\tTIME_VALUE : $tp{$no}{TIME_VALUE}\n";
			print "\tSBIN_NUM   : $tp{$no}{SBIN_NUM}\n";
			print "\tSBIN_NAME  : $tp{$no}{SBIN_NAM}\n\n";
			
