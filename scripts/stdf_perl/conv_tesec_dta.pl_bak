			print "\tLIMIT_ITEM_NAME: $tp{$no}{LIMIT_ITEM_NAME}\n";
			print "\tLIMIT_UNIT : $tp{$no}{LIMIT_UNIT}\n";
			print "\tLIMIT_VALRW: $tp{$no}{LIMIT_VALUE_RAW}\n";
