# (c) Copyright Fairchild Semiconductor Corperation, 1999
# All rights reserved
#
# MODIFICATION HISTORY:
#
# DATE       WHO             DESCRIPTION
# __________ ______________  __________________________________________________
# 11-02-1999 Steve Frampton  Original.  Contact Information:
#                            (207) 273-3364
#                            sframpto@fairchildsemi.com,
#                            sframpto@midcoast.com
#
# 02-02-2000 Steve Frampton  Fixed a number of EMIR _CNT fields.
# 02-09-2000 Steve Frampton  Added MRR init to fix MRR counts.
# 02-15-2000 Steve Frampton  uppercase LOT_ID.
#                            stripped delimiter chars from both
#                            tsr,ptr test_nam
#                            Changed definition of Infinity to be
#                            MAX since SAS can't handle it.
#                            Fixed MRR counts, as this was hosed.
# 02-21-2000 Steve Frampton  Used update_EMIR function instead of
#                            in-line code.
#                            Put in check for TEST PLAN part
# 03-20-2000 Steve Frampton  Changes made to accomodate longer test_plan_rev.
#                            test_plan_rev is converted from real number to
#                            integer by removing decimal point.
# 04-11-2000 Steve Frampton  Added -log_fn option
# 04-18-2000 Steve Frampton  Added -no_alarm option for eagle problem work
#                            around.  Can be stripped when resolved.
# 04-20-2000 Steve Frampton  TSR,WTSR.OPT.FLAG TEST_SDEV was invalid when 
#                            MIN=MAX.  Fixed.
# 05-01-2000 Steve Frampton  Added -reprobe option for eagle problem work
#                            around.  Can be stripped when resolved.
# 05-17-2000 Steve Frampton  Added -no_truncate_ptr option and default to
#                            truncating ptr records
# 10-10-2000 Steve Frampton  Set EMIR.MODE_COD to 'C' for test plans
# 01-05-2001 Steve Frampton  EWCR is no longer output or parsed by default
# 01-17-2001 Steve Frampton  Changed error message from WIR to MRR
# 01-30-2001 Scott Boothby   Initialize WIR & WRR WAFER_ID fields with MRR.SBLOT_ID.
# 01-30-2001 Steve Frampton  Add fix_bin_nam, fix_test_nam calls
#                            Add compress_name option
#

$useage = '
Convert an STDF V4 file to an STDF V3+ file for EDB

V4_2_PL [-ptr_checks [continue]] [-force_env] [-h]
        [-l loglevel] [-log_fn log]
	[-no_truncate_ptr]
	[-compress_name]
	[-no_alarm] [-reprobe]
        [-r record_list] [-tp ouput_test_plan_file] STDF_V4_File STDF+_File

OPTIONS
  -ptr_checks [continue]
    Checks if default PTR information is overridden.  (not valid
    for EDB).  If continue is specified, processing will continue
    with warnings, otherwise problems are fatal.

  -force_env
    Environment variable values will be used to populate records
    unconditionally (see ENVIRONMENT).

  -no_alarm
    Unconditionally set PTR.OPT_FLAG bit 0 to 0=No alarm
    Eagle work around.

  -reprobe
    Sets EMIR/MIR.RTST_COD based on MIR.SBLOT_ID
    Sets MRR.DISP_COD based on MIR.RTST_COD
    Eagle work around.

  -h
    Print this help message.

  -l loglevel 
    Where loglevel is a number > 0.  Higher loglevels provide
    more detail.

  -log_fn log
     Appends logging output to file name log.  STDERR is redefined.

  -r record_list
    Where record_list is an extended matching pattern.
    Only STDF+ output records that match record_list will
    be in the test data output file.  Example:  "EMIR|MRR".
    See RECORD MAPPING.

  -tp output_test_plan_file
    Outputs test plan file to file name specified.
    If this option is not provided, no test plan is output.
    If - is specified, test plan output is stdout.

  -compress_name
    Compress _ out of bin or test name after converting
    invalid characters to _.

ARGUMENTS
  STDF_V4_File
   STDF V4 Input File Name

  STDF+_File
   STDF+_Output_File Name.  If - is specified, output file is
   stdout.

ENVIRONMENT
  The following environment variables correspond to STDF+ EMIR output fields.

  MODE_COD, STAT_NUM, PART_TYP, OPER_NAM, TSTR_TYP, PRB_CARD, LOT_ID,
  SPEC_NAM, SPEC_REV, PKG_ID, PKG_TKPE, FACILITY

  If the corresponding field is not available from the STDF V4 MIR input field,
  then the field is populated with the ENVIRONMENT variable, except for SPEC_REV.

  The EMIR.SPEC_REV takes its value from the first defined value: MIR.SPEC_REV,
  ENV{SPEC_REV}, MIR.JOB_REV.
  
  will be populated with the environment variable SPEC_REV
  if it is defined, otherwise the MIR.SPEC_REV will be used.

  If the force_env command line option is set, the LOT_ID, SPEC_NAM, and
  SPEC_REV will take on the values of the environment variables, regardless
  of the values in the STDF V4 input file.  This is intended to be a test
  feature.

STATUS
  The high nibble is the status for the test plan results.
  The low order nibble is the status for the test data results.

  255 Fatal.  Test Data and Test Plan are not valid because of missing data.
  221 PTR test definition fields have changed.  Normally, this is fatal.
      If the -ptr_checks [continue] options were set, then output is valid
      stdf+, but data loaded into EDB will not be valid.
   13 No EPDR records were written to the ouput test plan file.  Test 
      plan output file is invalid.  This results if no PTR records
      are in the input file.  This status can only be returned if the 
      -tp option is in use.
   12 Not able to update EMIR in test data file.

RECORD MAPPING
  The following record mapping is provided.
  Note that V4 and STDF+ records may not have the same fields,
  even if the record names are the same.
  Specific fields are not listed.  Please inspect the source
  code for this information.


                      Optional
Input      Output     Output
STDF V4    STDF+      STDF+           Output
Data File  Data File  Test Plan File  Frequency
---------  ---------  --------------  ---------
FAR        EMIR 1)    EMIR 1)         One per file
MIR        EMIR 2)    EMIR 2)         
SDR        EMIR 3)    EMIR 3)         
WCR        WCR                        One per file
WIR        WIR                        One per wafer
 PIR        PIR                        One per part
 PRR 1)     PIR                        
  PTR        PTR      EPDR              See note below.
 PRR 2)     EPRR                       One per part
 SBR 3)     WSBR                       One per software bin
 HBR 4)     WHBR                       One per hardware bin
 TSR 5)     WTSR                       One per test
WRR        WRR                        One per wafer
SBR  6)    SBR                        One per software bin
HBR  7)    HBR                        One per hardware bin
TSR  8)    TSR                        One per test
PCR        MRR 
MRR        MRR        MRR             One per file

Notes:

PRRs labeled 1) and 2) are actually same record.   PRR 2) is shown
in input record order, PRR 1) is not.

EMIRs labeled 1), 2), and 3) are the same record.  Only one EMIR is
written per file.

SBR 3) and HBR 4) represent wafer bin information.  SBR 5) and SBR 6)
represent session bin information.

Only HBR, SBR, and TSR, and PCR records with HEAD_NUM=255 in the input
are used for the output.

Indented records denote that a record "belongs" to the bracketed types.
Example:  The PTR freqency can be interpreted as once per test, 
per part, per wafer (assuming wafer records exist in file).

EPDR records occur once per test within a file.
PTR records occur once per test execution.

' ;

# ' <- vim fix  

#
# Logging level definitions
# Change these to suite -l option behavior
#
$log_cnv = 1 ;
$log_trunc = 2 ; # text field overflows
$log_tp_errors = 2 ;
$log_ptr_errors = 2 ;
$log_cnt_overflow = 3 ;
$log_cnt_missing = 3 ;
$log_tsr_stats_errors = 3 ;
$log_IEEEfloat_pack_error = 3 ;
$log_spec_id = 3 ;
$log_trunc_bin_tests = 3 ;  # bin and test_nam field length overflow
$log_bad_chars = 3 ;  # test name bad characters
$log_tsr_neg_small_var_errors = 4 ;
$log_IEEEfloat_unpack_error = 5 ;
$log_cnt_overflow_event = 6 ;
$log_cnt_missing_event = 6 ;
# see V4 stdf standard for REC_TYP codes
$log_lot_records = 6 ;
$log_summary_records = 7 ;
$log_wafer_records = 8 ;
$log_part_records = 9 ;
$log_test_records = 10 ;
$log_generic_records = 11 ;

#
# default log level
#
$loglevel = 3 ;

#
# Load libraries
#
use Carp ;  # error messages - does not work within stdf_use.pl
# set path to executable for libraries
use FindBin ; 
use lib "$FindBin::Bin" ; # set up path for libraries the same as script
use lib $ENV{'STDF_PERL_LIB'} ; # look for libraries in this directory
use English ;
require "stdf_use.pl" ;  # libraries that are not generated

#
# Load Specifications
#
$in_spec='stdfV4.spec';
$out_spec='stdfPL.spec' ;
#
# stdfV4.pl and stdfPL.pl are loaded over
# routines from generate_all
# stdfV4.pl and stdfPL.pl will not support
# VMS files when not running on VMS
#
{
package in ;
use Carp ;
if ( !eval(&::generate_all($::in_spec )))
  { confess $@ ; }
require 'stdfV4.pl' ;
}
{
package out ;
use Carp ;
if ( !eval(&::generate_all($::out_spec )))
  { confess $@ ; }
require 'stdfPL.pl' ;
}

# Default record list
$record_list = 
  "EMIR|WIR|PIR|PTR|EPRR|WHBR|WSBR|WTSR|WRR|HBR|SBR|TSR|MRR" ;

#
# Parse command line arguments
#
$ptr_over_ride=0 ;
$force_env=0 ;
$truncate_ptr = 1 ;
$compress_name = 0 ;
$cmd = $PROGRAM_NAME." ". join(" ", @ARGV) ;  # save cmd line
while (substr($ARGV[0],0,1) eq '-' && !($ARGV[0] eq '-'))  # parse all options
  {
  if ($ARGV[0] eq '-ptr_checks')
    {
    $ptr_checks=1; shift ;
    if ($ARGV[0] eq 'continue')
      {
      $ptr_over_ride=1; shift;
      }
    }
  elsif ($ARGV[0] eq '-r') { shift; $record_list = shift; }
  elsif ($ARGV[0] eq '-force_env') { $force_env=1; shift ; }
  elsif ($ARGV[0] eq '-no_alarm') { $no_alarm=1; shift ; }
  elsif ($ARGV[0] eq '-reprobe') { $reprobe=1; shift ; }
  elsif ($ARGV[0] eq '-compress_name') { $compress_name=1; shift ; }
  elsif ($ARGV[0] eq '-no_truncate_ptr') { $truncate_ptr=0; shift ; }
  elsif ($ARGV[0] eq '-tp')
    {
    shift;
    $tp_fn = shift;
    }
  elsif ($ARGV[0] eq '-l') { shift; $loglevel = shift; }
  elsif ($ARGV[0] eq '-log_fn') { shift; $log_fn = shift; }
  elsif ($ARGV[0] eq '-h') { shift; print $useage; exit ; }
  else { print $useage ; exit ; }
  }
if (defined($log_fn))
  {
  open_log($log_fn) ;  # redefine STDERR and LOG
  }
if (defined( $tp_fn ) )
  {
  if ($tp_fn eq '-')
    {
    open TPOUT, ">&STDOUT" or confess &lh, "Could not open test plan as STDOUT" ;
    }
  else
    {
    open TPOUT, ">$tp_fn" or confess &lh, "Could not open test plan for output $tp_fn\n" ;
    }
  binmode TPOUT ;
  }

if ($ARGV[0])
  {
  $in_fn = shift ;
  if ( $in_fn eq $tp_fn )
    { confess &lh, "Inputfilename=TestPlanfilename: $in_fn " ; }
  open INPUT, "<$in_fn" or confess &lh, "Could not open input file name $in_fn\n" ;
  }
binmode INPUT ;
if ($ARGV[0] && !($ARGV[0] eq '-'))
  {
  $out_fn = shift ;
  if (($in_fn eq $out_fn) && !($out_fn eq ''))
    { confess &lh, "Inputfilename=Outputfilename: $in_fn " ; }
  open OUTPUT, ">$out_fn" or confess &lh, "Could not open output file name $out_fn\n" ;
  }
else
  {
  $out_fn = '-' ;
  warn &lh, "No EMIR counts ! STDOUT should only be used for debug." ;
  open OUTPUT, ">&STDOUT" or confess &lh, "Could not open output as STDOUT\n" ;
  }
binmode OUTPUT ;
if ( $tp_fn eq $out_fn )  
  { confess &lh, "TestPlanfilename=Outputfilename: $out_fn " ; }
wlog($log_cnv, "start ".$cmd."\n") ;

#
# call loop to convert records
#
$rc = 0 ;
convert_file(\*INPUT) ;
$rc = $tp_rc+0xF*$rc ;   # Low Nibble is return code for test plan
                         # High Nibble is return code for other stuff
                         # If High Nibble is set, caller should assume
                         # that test plan is bad too
                         # This is the only exit point for normal processing
                         # Note that there wont be a test plan return code
                         # for fatal conditions
 
exit($rc) ;  # return code is a global used within this file
             # don't ever reset from non-zero to zero !
             # in general, is a valid stdf file
             # but not compatible with edb

#
# Mapping subroutines that get called within convert_file calling tree
# From here to end of file
#
sub convert_FAR  # empty sub required to force Engine to unpack
{
wlog( $log_lot_records, "begin convert_FAR\n" ) ;
%out::mrr = %{$out::init{mrr}} ;  # initialize mrr so that counts are set
wlog( $log_lot_records, "end convert_FAR\n" ) ;
}

sub convert_MIR  # empty sub required to force Engine to unpack
                 # see convert_SDR
{
wlog( $log_lot_records, "begin convert_MIR\n" ) ;
wlog( $log_lot_records, "end convert_MIR\n") ;
}

sub convert_SDR
{
wlog( $log_lot_records, "begin convert_SDR\n") ;
$convert_SDR_called = 1 ; # state variable to indicate if convert_SDR was
                          # called.  If SDR record was not in file,
                          # record following MIR must call convert_SDR
#
# SDR has the last data needed for the EMIR
# ...except for the count records that is
#
$out::emir{cpu_type}=$running_cpu_type; # U*1
$out::emir{stdf_ver}=${out::init{emir}{stdf_ver}}; # U*1
setr($out::emir{mode_cod}, $in::mir{mode_cod}, ${out::init{emir}{mode_cod}})
  ||($out::emir{mode_cod} = $ENV{MODE_COD})
  ||confess &lh, 'emir{mode_cod} not defined'; # C*1, C*1
setr($out::emir{stat_num}, $in::mir{stat_num}, ${out::init{emir}{stat_num}})
  ||($out::emir{stat_num} = $ENV{STAT_NUM})
  ||confess &lh, 'emir{stat_num} not defined'; # U*1, U*1
seto($out::emir{test_cod}, $in::mir{test_cod}, ${out::init{emir}{test_cod}})||confess &lh, 'emir{test_cod} not defined'; # C*3, C*n
seto($out::emir{prot_cod}, $in::mir{prot_cod}, ${out::init{emir}{prot_cod}})||confess &lh, 'emir{prot_cod} not defined'; # C*1, C*1
seto($out::emir{cmod_cod}, $in::mir{cmod_cod}, ${out::init{emir}{cmod_cod}})||confess &lh, 'emir{cmod_cod} not defined'; # C*1, C*1
seto($out::emir{setup_t}, $in::mir{setup_t}, ${out::init{emir}{setup_t}})||confess &lh, 'emir{setup_t} not defined'; # U*4, U*4
setr($out::emir{start_t}, $in::mir{start_t}, ${out::init{emir}{start_t}})||confess &lh, 'emir{start_t} not defined'; # U*4, U*4
seto($out::emir{temp}, $in::mir{tst_temp}, ${out::init{emir}{temp}})||confess &lh, 'emir{temp} not defined'; # R*4, C*n
$out::emir{ssum_cnt}=${out::init{emir}{ssum_cnt}}; # I*4 
$out::emir{sswb_cnt}=${out::init{emir}{sswb_cnt}}; # I*4
$out::emir{shwb_cnt}=${out::init{emir}{shwb_cnt}}; # I*4
$out::emir{ssyn_cnt}=${out::init{emir}{ssyn_cnt}}; # I*4
$out::emir{shis_cnt}=${out::init{emir}{shis_cnt}}; # I*4
$out::emir{wsum_cnt}=${out::init{emir}{wsum_cnt}}; # I*4
$out::emir{wswb_cnt}=${out::init{emir}{wswb_cnt}}; # I*4
$out::emir{whwb_cnt}=${out::init{emir}{whwb_cnt}}; # I*4
$out::emir{wsyn_cnt}=${out::init{emir}{wsyn_cnt}}; # I*4
$out::emir{whis_cnt}=${out::init{emir}{whis_cnt}}; # I*4
$out::emir{psum_cnt}=${out::init{emir}{psum_cnt}}; # I*4
$out::emir{pres_cnt}=${out::init{emir}{pres_cnt}}; # I*4
$out::emir{fres_cnt}=${out::init{emir}{fres_cnt}}; # I*4
$out::emir{psyn_cnt}=${out::init{emir}{psyn_cnt}}; # I*4
$out::emir{phis_cnt}=${out::init{emir}{phis_cnt}}; # I*4
setr($out::emir{part_typ}, $in::mir{part_typ}, ${out::init{emir}{part_typ}}) ||($out::emir{part_typ} = $ENV{PART_TYP}) ||confess &lh, 'emir{part_typ} not defined'; # C*n, C*n

#
# truncate part_typ because edb tdl chokes on it
#
if (length($out::emir{part_typ}) > $edb_part_typ_len )
  {
  wlog( $log_trunc, "emir{part_typ} length > edb max of $edb_part_typ_len, truncating\n") ;
  $out::emir{part_typ} = substr($out::emir{part_typ},0,$edb_part_typ_len) ;
  }

#
# job_nam is required, since it can be used for the spec_nam
# but we trap for it at spec_nam
#
seto($out::emir{job_nam}, $in::mir{job_nam}, ${out::init{emir}{job_nam}})||confess &lh, 'emir{job_nam} not defined'; # C*n, C*n
seto($out::emir{oper_nam}, $in::mir{oper_nam}, ${out::init{emir}{oper_nam}})
  ||($out::emir{oper_nam} = $ENV{OPER_NAM})
  ||confess &lh, 'emir{oper_nam} not defined'; # C*n, C*n
seto($out::emir{node_nam}, $in::mir{node_nam}, ${out::init{emir}{node_nam}})||confess &lh, 'emir{node_nam} not defined'; # C*n, C*n
setr($out::emir{tstr_typ}, $in::mir{tstr_typ}, ${out::init{emir}{tstr_typ}})
  ||($out::emir{tstr_typ} = $ENV{TSTR_TYP})
  ||confess &lh, 'emir{tstr_typ} not defined'; # C*n, C*n
seto($out::emir{exec_typ}, $in::mir{exec_typ}, ${out::init{emir}{exec_typ}})||confess &lh, 'emir{exec_typ} not defined'; # C*n, C*n
seto($out::emir{supr_nam}, $in::mir{supr_nam}, ${out::init{emir}{supr_nam}})||confess &lh, 'emir{supr_nam} not defined'; # C*n, C*n
seto($out::emir{hand_id}, $in::sdr{hand_id}, ${out::init{emir}{hand_id}})||confess &lh, 'emir{hand_id} not defined'; # C*n, C*n
seto($out::emir{sblot_id}, $in::mir{sblot_id}, ${out::init{emir}{sblot_id}})||confess &lh, 'emir{sblot_id} not defined'; # C*n, C*n
#
# Eagle work around to populate MIR.rtst_cod
# This block of code can be stripped once the -reprobe option
# is no longer needed
#
if ($reprobe
    && ! ($in::emir{rtst_cod} =~ /(P)|(R)/)
    && $in::mir{sblot_id} =~ /\S/ )
  {
  if ($in::mir{sblot_id} =~ /REPROBE/)
    {
    $in::mir{rtst_cod} = 'R' ;
    $out::emir{sblot_id} = ${out::init{emir}{sblot_id}} ;
    }
  # bearing in mind that PROBE is part of REPROBE
  elsif ($in::mir{sblot_id} =~ /(PROBE)|(UNKNOWN)/)
    {
    $in::mir{rtst_cod} = 'P' ;
    $out::emir{sblot_id} = ${out::init{emir}{sblot_id}} ;
    }
  else
    {
    wlog(2, " -reprobe option, mir{sblot_id} not understood for emir{rtst_cod} \n") ;
    }
  }
seto($out::emir{rtst_cod}, $in::mir{rtst_cod}, ${out::init{emir}{rtst_cod}})||confess &lh, 'emir{rtst_cod} not defined'; # C*1, C*1


seto($out::emir{job_rev}, $in::mir{job_rev}, ${out::init{emir}{job_rev}})||confess &lh, 'emir{job_rev} not defined'; # C*n, C*n
seto($out::emir{proc_id}, $in::mir{proc_id}, ${out::init{emir}{proc_id}})||confess &lh, 'emir{proc_id} not defined'; # C*n, C*n
# hand coded
seto($out::emir{prb_card}, $in::sdr{card_id}, ${out::init{emir}{prb_card}})
  ||($out::emir{prb_card} = $ENV{PRB_CARD})
  ||confess &lh, 'emir{prb_card} not defined'; # C*n, C*n
# hand coded.  Probably not needed, significant number of nulls in db
seto($out::emir{oper_id}, $in::mir{oper_nam}, ${out::init{emir}{oper_nam}})||confess &lh, 'emir{oper_id} not defined'; # C*n, C*n
#
# allow identifiers to be overridden by environment variables
# 
#
if ($force_env)
  {
  ($out::emir{lot_id} = $ENV{LOT_ID})||confess &lh, 'emir{lot_id} not defined'; # C*n, C*n
  ;
  ($out::emir{spec_nam} = $ENV{SPEC_NAM})||confess &lh, 'emir{spec_nam} or emir{job_nam} not defined'; # C*n, C*n
 ;
  ($out::emir{spec_rev} = $ENV{SPEC_REV})||confess &lh, 'emir{spec_rev} not defined'; # C*n, C*n
 ;
  }
else
  {
  setr($out::emir{lot_id}, $in::mir{lot_id}, ${out::init{emir}{lot_id}})
    ||($out::emir{lot_id} = $ENV{LOT_ID})
    ||confess &lh, 'emir{lot_id} not defined'; # C*n, C*n
  setr($out::emir{spec_nam}, $in::mir{spec_nam}, ${out::init{emir}{spec_nam}})
    || setr($out::emir{spec_nam}, $in::mir{job_nam}, ${out::init{emir}{job_nam}})
    ||($out::emir{spec_nam} = $ENV{SPEC_NAM})  # We go after the environment last
    ||confess &lh, 'emir{spec_nam} or emir{job_nam} not defined'; # C*n, C*n
  setr($out::emir{spec_rev}, $in::mir{spec_ver}, ${out::init{emir}{spec_rev}})
    ||($out::emir{spec_rev} = $ENV{SPEC_REV})  # Note that we try the environment second
    ||($out::emir{spec_rev} = $in::mir{job_rev})
    ||confess &lh, 'emir{spec_rev} not defined'; # C*n, C*n
  }
#
# make lot_id upper case for ewb
#
$out::emir{lot_id} = uc($out::emir{lot_id}) ;
#
# attempt to turn spec_rev into integer
#
my $old_spec_rev=$out::emir{spec_rev} ;
if ( $out::emir{spec_rev} =~ s/([0-9]+)[.]([0-9]*)/$1$2/ )
  {
  wlog($log_tp_errors, "emir{spec_rev} was converted from $old_spec_rev to $out::emir{spec_rev}\n") ;
  }

if (! ($out::emir{spec_rev} =~ /[0-9]+/) )
  {
  wlog(0, "emir{spec_rev} was converted from $old_spec_rev to $out::emir{spec_rev}\n") ;
  confess &lh, "emir{spec_rev}=$out::emir{spec_rev} needs integer format for EDB\n" ;
  }

#
# Check the length of critial fields
# We will make this fatal, as it could corrupt data outside of session
# length values live in edb_defs.pl
#
if ( length($out::emir{lot_id}) > $edb_lot_id_len)
  {
  wlog($log_trunc, "emir{lot_id} length > edb max of $edb_lot_id_len, truncating\n") ;
  $out::emir{lot_id} = substr($out::emir{lot_id},0,$edb_lot_id_len) ;
  }
( length($out::emir{spec_nam}) > $edb_spec_nam_len)
  && confess &lh, "emir{spec_nam} length > edb max of $edb_spec_nam_len\n" ;
( length($out::emir{spec_rev}) > $edb_spec_rev_len)
  && confess &lh, "emir{spec_rev} length > edb max of $edb_spec_rev_len\n" ;

# hand coded
seto($out::emir{load_brd}, $in::sdr{load_id}, ${out::init{emir}{load_brd}})||confess &lh, 'emir{load_brd} not defined'; # C*n, C*n
# hand coded, correct ?
seto($out::emir{device}, $in::mir{dsgn_rev}, ${out::init{emir}{device}})||confess &lh, 'emir{device} not defined'; # C*n, C*n
# needed ?
$out::emir{lot_strt}=${out::init{emir}{lot_strt}}; # C*n
# hand coded, correct ?
seto($out::emir{lot_type}, $in::mir{mode_cod}, ${out::init{emir}{mode_cod}})||confess &lh, 'emir{lot_type} not defined'; # C*1, C*1
# hand coded.  Probably not needed, significant number of nulls in db
seto($out::emir{des_rev}, $in::mir{dsgn_rev}, ${out::init{emir}{des_rev}})
#  ||($out::emir{des_rev} = $ENV{DES_REV})
  ||confess &lh, 'emir{des_rev} not defined'; # C*n, C*n
# hand coded
seto($out::emir{family}, $in::mir{family_id}, ${out::init{emir}{family}})
#  ||($out::emir{family} = $ENV{FAMILY})
  ||confess &lh, 'emir{family} not defined'; # C*n, C*n
$out::emir{group}=${out::init{emir}{group}}; # C*n
$out::emir{int_lev}=${out::init{emir}{int_lev}}; # C*n
# hand coded
seto($out::emir{pkg_id}, $in::mir{pkg_typ}, ${out::init{emir}{pkg_id}})
  ||($out::emir{pkg_id} = $ENV{PKG_ID})
  ||confess &lh, 'emir{pkg_id} not defined'; # C*n, C*n
# hand coded, probably not needed, sig number of nulls in db
seto($out::emir{pkg_type}, $in::mir{pkg_typ}, ${out::init{emir}{pkg_type}})
#  ||($out::emir{pkg_type} = $ENV{PKG_TYPE})
  ||confess &lh, 'emir{pkg_type} not defined'; # C*n, C*n
$out::emir{customer}=${out::init{emir}{customer}}; # C*n
$out::emir{drawing}=${out::init{emir}{drawing}}; # C*n
$out::emir{facility}=${out::init{emir}{facility}}; # C*n
# hand coded, environment variable
seto($out::emir{facility}, $ENV{FACILITY}, ${out::init{emir}{facility}})||confess &lh, 'emir{facility} not defined'; # C*n, C*n
$out::emir{gold_dev}=${out::init{emir}{gold_dev}}; # C*n

$out::emir{spec_rev} = pad($out::emir{spec_rev},"\0") ; # pad with nulls to default length
$out::emir{spec_nam} =~ s/ +$// ; # remove trailing spaces
$out::emir{spec_nam} =~ s/ /_/g ; # change spaces to underscores ('_').

if ( "EMIR" =~ /$record_list/ )
  {
  $emir_bin = &out::pack_EMIR(\%out::emir) ;
  print OUTPUT $emir_bin ;
  }
#
# output EMIR for tp record
# be careful of changing EMIR fields, as EMIR is re-written
# with the counts
#
if ( defined($tp_fn) )
  {
  my $tmp_ssum_cnt = $out::emir{ssum_cnt} ;  # save results
  my $tmp_mode_cod = $out::emir{mode_cod} ;  # save
  $out::emir{ssum_cnt} = 1 ;
  # make any tp specific changes below
  # or pass it off it tp resolver
  $out::emir{mode_cod} = 'C' ; # configuration data
  print TPOUT &out::pack_EMIR(\%out::emir) ;
  $out::emir{ssum_cnt} = $tmp_ssum_cnt ;  # restore
  $out::emir{mode_cod} = $tmp_mode_cod ;  # save
  TPOUT->flush ;
  }
wlog( $log_lot_records, "end convert_SDR\n") ;

}


#
# EWCR is not currently a requirement
# partially coded and not well tested
#
sub convert_WCR
{
# call convert_SDR if it was not called, e.g. SDR is not in input file.
if (! $convert_SDR_called ) { convert_SDR() ; }
wlog( $log_lot_records, "begin convert_WCR\n") ;
if ( "EWCR" =~ /$record_list/ )
  {
  setr($out::ewcr{wafr_siz}, $in::wcr{wafr_siz}, ${out::init{ewcr}{wafr_siz}})
    ||confess &lh, 'ewcr{wafr_siz} not defined'; # R*4, R*4
  setr($out::ewcr{die_ht}, $in::wcr{die_ht}, ${out::init{ewcr}{die_ht}})||confess &lh, 'ewcr{die_ht} not defined'; # R*4, R*4
  setr($out::ewcr{die_wid}, $in::wcr{die_wid}, ${out::init{ewcr}{die_wid}})||confess &lh, 'ewcr{die_wid} not defined'; # R*4, R*4
  seto($out::ewcr{wf_units}, $in::wcr{wf_units}, ${out::init{ewcr}{wf_units}})||confess &lh, 'ewcr{wf_units} not defined'; # U*1, U*1
  seto($out::ewcr{wf_flat}, $in::wcr{wf_flat}, ${out::init{ewcr}{wf_flat}})||confess &lh, 'ewcr{wf_flat} not defined'; # C*1, C*1
  seto($out::ewcr{center_x}, $in::wcr{center_x}, ${out::init{ewcr}{center_x}})||confess &lh, 'ewcr{center_x} not defined'; # I*2, I*2
  seto($out::ewcr{center_y}, $in::wcr{center_y}, ${out::init{ewcr}{center_y}})||confess &lh, 'ewcr{center_y} not defined'; # I*2, I*2
  seto($out::ewcr{pos_x}, $in::wcr{pos_x}, ${out::init{ewcr}{pos_x}})||confess &lh, 'ewcr{pos_x} not defined'; # C*1, C*1
  seto($out::ewcr{pos_y}, $in::wcr{pos_y}, ${out::init{ewcr}{pos_y}})||confess &lh, 'ewcr{pos_y} not defined'; # C*1, C*1
  # values below not supported by V4
  $out::ewcr{start_x}=${out::init{ewcr}{start_x}}; # I*2
  $out::ewcr{start_y}=${out::init{ewcr}{start_y}}; # I*2
  # Required ? Derived ? Needs more coding
  $out::ewcr{row_cnt}=${out::init{ewcr}{row_cnt}}; # I*2
  # Required ? Derived ? Needs more coding
  $out::ewcr{col_cnt}=${out::init{ewcr}{col_cnt}}; # I*2
  $out::ewcr{origin}=${out::init{ewcr}{origin}}; # I*1
  $out::ewcr{praxis}=${out::init{ewcr}{praxis}}; # I*1
  $out::ewcr{refpt1_x}=${out::init{ewcr}{refpt1_x}}; # I*2
  $out::ewcr{refpt1_y}=${out::init{ewcr}{refpt1_y}}; # I*2
  $out::ewcr{refpt2_x}=${out::init{ewcr}{refpt2_x}}; # I*2
  $out::ewcr{refpt2_y}=${out::init{ewcr}{refpt2_y}}; # I*2
  $out::ewcr{refpt3_x}=${out::init{ewcr}{refpt3_x}}; # I*2
  $out::ewcr{refpt3_y}=${out::init{ewcr}{refpt3_y}}; # I*2
  $out::ewcr{refpt4_x}=${out::init{ewcr}{refpt4_x}}; # I*2
  $out::ewcr{refpt4_y}=${out::init{ewcr}{refpt4_y}}; # I*2
  $out::ewcr{def_unit}=${out::init{ewcr}{def_unit}}; # U*1
  print OUTPUT &out::pack_EWCR(\%out::ewcr) ;
  }
wlog( $log_lot_records, "end convert_WCR\n") ;
}

sub convert_WIR
{
# call convert_SDR if it was not called, e.g. SDR is not in input file.
if (! $convert_SDR_called ) { convert_SDR() ; }
wlog( $log_wafer_records, "begin convert_WIR\n") ;
$reading_wafer = 1 ;

undef %out::wir ;  # initialize to undefined
seto($out::wir{head_num}, $in::wir{head_num}, ${out::init{wir}{head_num}})||confess &lh, 'wir{head_num} not defined'; # U*1, U*1
$out::wir{pad_byte}=${out::init{wir}{pad_byte}}; # B*1

#
# set to wir, if=default, set to mir, else die
# mir part not tested
#
setr($out::wir{start_t}, $in::wir{start_t}, ${out::init{wir}{start_t}})
  || setr($out::wir{start_t}, $in::mir{start_t}, ${out::init{wir}{start_t}})
  || confess &lh, 'wir{start_t} not defined'; # U*4, U*4
#setr($out::wir{wafer_id}, $in::wir{wafer_id}, ${out::init{wir}{wafer_id}})
seto($out::wir{wafer_id}, $in::wir{wafer_id}, $out::emir{sblot_id})
  || confess &lh, 'wir{wafer_id} not defined'; # C*n, C*n
if ( "WIR" =~ /$record_list/ )
  { print OUTPUT &out::pack_WIR(\%out::wir) ; }
wlog( $log_wafer_records, "end convert_WIR\n") ;
}

